{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist/out-tsc",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "sourceMap": true,
    "declaration": false,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "useDefineForClassFields": false,
    "lib": [
      "ES2022",
      "dom"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@placeos/assets": ["libs/assets/src/index.ts"],
      "@placeos/bookings": ["libs/bookings/src/index.ts"],
      "@placeos/calendar": ["libs/calendar/src/index.ts"],
      "@placeos/catering": ["libs/catering/src/index.ts"],
      "@placeos/common": ["libs/common/src/index.ts"],
      "@placeos/components": ["libs/components/src/index.ts"],
      "@placeos/events": ["libs/events/src/index.ts"],
      "@placeos/explore": ["libs/explore/src/index.ts"],
      "@placeos/form-fields": ["libs/form-fields/src/index.ts"],
      "@placeos/mocks": ["libs/mocks/src/index.ts"],
      "@placeos/organisation": ["libs/organisation/src/index.ts"],
      "@placeos/payments": ["libs/payments/src/index.ts"],
      "@placeos/spaces": ["libs/spaces/src/index.ts"],
      "@placeos/users": ["libs/users/src/index.ts"]
    },
    "types": ["google.maps"]
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
